# TwojTenis MCP Server — v0.2.0 Configuration
# Copy to .env and fill in required values.

# --- Required ---

# Main API (Azure-hosted JSON endpoint)
TWOJTENIS_MAIN_API_URL=https://app-twojtenis-api-p-weu.azurewebsites.net

# Auth0 application client ID
AUTH0_CLIENT_ID=<your-auth0-client-id>

# --- Optional overrides (production defaults shown) ---

TWOJTENIS_REQUEST_TIMEOUT=30

AUTH0_DOMAIN=twojtenis.eu.auth0.com
AUTH0_AUDIENCE=https://api.twojetenis.pl   # extra 'e' is intentional — do NOT fix
AUTH0_REDIRECT_URI=https://app.twojtenis.pl
AUTH0_SCOPE=openid profile email offline_access

# Set to 'false' to watch headless browser during login (debug only)
AUTH0_BROWSER_HEADLESS=true
AUTH0_BROWSER_TIMEOUT=60

# Path to a custom Chromium binary (e.g. AWS Lambda Sparticuz/chromium layer)
# AUTH0_BROWSER_EXECUTABLE_PATH=/opt/chromium/chromium
